# ==============================================================
# AI Marketing Platform — Environment Variables
# ==============================================================
# Copy this file to .env and fill in the values before running
# docker-compose up
# ==============================================================

# ── Node.js API ──────────────────────────────────────────────

# JWT secret for signing authentication tokens (CHANGE THIS!)
JWT_SECRET=your-secure-random-string-here

# Postgres
DATABASE_URL=postgres://user:password@postgres:5432/marketing_platform

# Redis
REDIS_URL=redis://redis:6379

# Kafka
KAFKA_BROKERS=kafka:9092

# ── Python AI Engine ─────────────────────────────────────────

# Required: OpenAI API key for LLM calls
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Pinecone for RAG (continuous learning)
PINECONE_API_KEY=

# Optional: Alternative LLM providers
ANTHROPIC_API_KEY=
GEMINI_API_KEY=
